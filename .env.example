# ==============================
# THIAMSTREETWEAR — Configuration
# Copie ce fichier en .env et remplis les valeurs
# ==============================

# Django
SECRET_KEY=change-moi-avec-une-cle-secrete-longue-et-aleatoire
DEBUG=False
ALLOWED_HOSTS=thiamstreetwear.com,www.thiamstreetwear.com

# Base de données MySQL
DB_NAME=boutik_db
DB_USER=boutik_user
DB_PASSWORD=mot-de-passe-fort-ici
DB_HOST=db
DB_PORT=3306
DB_ROOT_PASSWORD=mot-de-passe-root-fort-ici

# Stripe (optionnel)
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SEO
SITE_URL=https://thiamstreetwear.com

# SEA — Google Tag Manager (contient GA4 + Google Ads)
# Crée un compte sur tagmanager.google.com → récupère ton ID GTM-XXXXXXX
GTM_ID=GTM-XXXXXXX

# SEA — Meta Pixel (Facebook / Instagram Ads)
# Va sur business.facebook.com/events_manager → crée un pixel → copie l'ID
META_PIXEL_ID=XXXXXXXXXXXXXXXXXX
